generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TickerType {
  STOCK
  ETF
}

enum EntityType {
  PERSON
  INSTITUTION
  ANALYST
}

enum ActivityType {
  CONGRESS_TRADE
  INSIDER_TRADE
  INSTITUTIONAL_CHANGE
  ANALYST_ACTION
}

enum AlertRuleType {
  CONGRESS_TRADE
  INSIDER_BUY
  ANALYST_RATING_CHANGE
  ARTICLE_MENTION
}

enum SourceType {
  RSS
  API
  SITE
}

enum ArticleStatus {
  DRAFT
  REVIEW
  PUBLISHED
}

enum PeriodType {
  QUARTER
  ANNUAL
}

model User {
  id         String      @id @default(cuid())
  email      String      @unique
  createdAt  DateTime    @default(now())
  watchlists Watchlist[]
  alertRules AlertRule[]
  notifications Notification[]
  subscription  Subscription?
}

model Ticker {
  id        String            @id @default(cuid())
  symbol    String            @unique
  name      String
  type      TickerType
  exchange  String?
  sector    String?
  prices    PriceSnapshot[]
  facts     Fundamental[]
  mentions  ArticleMention[]
  activity  ActivityEvent[]
  scores    SignalScore[]
  createdAt DateTime          @default(now())

  @@index([symbol])
}

model PriceSnapshot {
  id        String   @id @default(cuid())
  tickerId  String
  date      DateTime
  open      Float?
  high      Float?
  low       Float?
  close     Float?
  volume    Float?
  ticker    Ticker   @relation(fields: [tickerId], references: [id])

  @@unique([tickerId, date])
  @@index([date])
}

model Fundamental {
  id         String     @id @default(cuid())
  tickerId   String
  periodEnd  DateTime
  periodType PeriodType
  revenue    Float?
  eps        Float?
  grossMargin Float?
  freeCashFlow Float?
  ticker     Ticker     @relation(fields: [tickerId], references: [id])

  @@index([tickerId, periodEnd])
}

model Author {
  id        String    @id @default(cuid())
  name      String
  bio       String?
  profileUrl String?
  articles  Article[]
}

model Article {
  id          String           @id @default(cuid())
  slug        String           @unique
  title       String
  summary     String
  content     String
  bodyMarkdown String?
  preview     String?
  paywalled   Boolean          @default(false)
  publishedAt DateTime
  status      ArticleStatus    @default(PUBLISHED)
  tickers     String[]         @default([])
  themes      String[]         @default([])
  sourceUrls  String[]         @default([])
  authorId    String
  author      Author           @relation(fields: [authorId], references: [id])
  rawNewsId   String?
  rawNews     RawNews?         @relation(fields: [rawNewsId], references: [id])
  mentions    ArticleMention[]
  tags        ArticleTag[]
  sources     ArticleSource[]
  createdAt   DateTime         @default(now())

  @@index([publishedAt])
}

model ArticleSection {
  id        String   @id @default(cuid())
  articleId String
  title     String
  body      String
  order     Int
  article   Article  @relation(fields: [articleId], references: [id])

  @@index([articleId, order])
}

model Tag {
  id    String       @id @default(cuid())
  name  String       @unique
  items ArticleTag[]
}

model ArticleTag {
  id        String  @id @default(cuid())
  articleId String
  tagId     String
  article   Article @relation(fields: [articleId], references: [id])
  tag       Tag     @relation(fields: [tagId], references: [id])

  @@unique([articleId, tagId])
}

model ArticleMention {
  id        String  @id @default(cuid())
  articleId String
  tickerId  String
  article   Article @relation(fields: [articleId], references: [id])
  ticker    Ticker  @relation(fields: [tickerId], references: [id])

  @@unique([articleId, tickerId])
}

model Entity {
  id        String        @id @default(cuid())
  name      String
  type      EntityType
  profile   String?
  website   String?
  activity  ActivityEvent[]
  createdAt DateTime      @default(now())

  @@index([type])
}

model ActivityEvent {
  id          String       @id @default(cuid())
  type        ActivityType
  tickerId    String
  entityId    String
  action      String
  amount      String?
  occurredAt  DateTime
  confidence  String?
  sourceId    String?
  meta        Json?
  ticker      Ticker       @relation(fields: [tickerId], references: [id])
  entity      Entity       @relation(fields: [entityId], references: [id])
  source      Source?      @relation(fields: [sourceId], references: [id])

  @@index([tickerId, occurredAt])
  @@index([entityId, occurredAt])
  @@index([type, occurredAt])
}

model Source {
  id          String          @id @default(cuid())
  name        String          @default("")
  type        SourceType      @default(RSS)
  url         String          @unique
  enabled     Boolean         @default(true)
  publisher   String
  retrievedAt DateTime
  articles    ArticleSource[]
  activity    ActivityEvent[]
}

model RawNews {
  id          String   @id @default(cuid())
  url         String   @unique
  title       String
  snippet     String
  publisher   String
  publishedAt DateTime
  contentText String?
  tickers     String[] @default([])
  themes      String[] @default([])
  fetchedAt   DateTime @default(now())
  articles    Article[]

  @@index([publishedAt])
}

model ArticleSource {
  id        String  @id @default(cuid())
  articleId String
  sourceId  String
  label     String?
  article   Article @relation(fields: [articleId], references: [id])
  source    Source  @relation(fields: [sourceId], references: [id])

  @@unique([articleId, sourceId])
}

model Watchlist {
  id        String          @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime        @default(now())
  user      User            @relation(fields: [userId], references: [id])
  items     WatchlistItem[]
  entities  WatchlistEntity[]
}

model WatchlistItem {
  id          String     @id @default(cuid())
  watchlistId String
  tickerId    String
  watchlist   Watchlist  @relation(fields: [watchlistId], references: [id])
  ticker      Ticker     @relation(fields: [tickerId], references: [id])

  @@unique([watchlistId, tickerId])
}

model WatchlistEntity {
  id          String     @id @default(cuid())
  watchlistId String
  entityId    String
  watchlist   Watchlist  @relation(fields: [watchlistId], references: [id])
  entity      Entity     @relation(fields: [entityId], references: [id])

  @@unique([watchlistId, entityId])
}

model AlertRule {
  id        String   @id @default(cuid())
  userId    String
  type      AlertRuleType
  params    Json
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, isActive])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
}

model Subscription {
  id                   String   @id @default(cuid())
  userId               String   @unique
  plan                 String
  status               String
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodEnd     DateTime?
  createdAt            DateTime @default(now())
  user                 User     @relation(fields: [userId], references: [id])
}

model JobRun {
  id        String   @id @default(cuid())
  jobName   String
  startedAt DateTime
  endedAt   DateTime?
  status    String
  logs      String?
}


model SignalScore {
  id        String   @id @default(cuid())
  tickerId  String
  asOf      DateTime
  score     Float
  components Json?
  ticker    Ticker   @relation(fields: [tickerId], references: [id])

  @@unique([tickerId, asOf])
}
